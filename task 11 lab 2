#include <Arduino_HS300x.h>
#include <Arduino_BMI270_BMM150.h> // For magnetometer (BMM150)
#include <Arduino_APDS9960.h>

// --- Optimized Technical Thresholds & Configuration ---
const int SAMPLE_PERIOD_MS = 1000;    // Continuous monitoring cycle period
const int COOLDOWN_MS      = 5000;    // Event re-trigger cooldown (5s)

// Thresholds for single modality flags
const float HUMID_JUMP_THRESH    = 5.0;  // >5.0% RH jump from baseline
const float TEMP_RISE_THRESH     = 0.5;  // >0.5°C rise from baseline
const float MAG_SHIFT_THRESH     = 10.0; // >10 uT magnitude shift from baseline
const float CLEAR_CHANGE_PERCENT = 20.0; // >20% change in clear light from baseline

// --- System State Variables ---
enum EventState {
  STATE_NORMAL,
  STATE_BREATH,
  STATE_MAGNETIC,
  STATE_LIGHT
};
EventState currentEvent = STATE_NORMAL;
unsigned long lastEventTime = 0;

// Calibrated baseline values (averaged in setup)
float baseRh, baseTemp, baseMag, baseClear;
int baseR, baseG, baseB;

void initialCalibration() {
  const int NUM_CALIB_SAMPLES = 50;
  Serial.println("--- Starting Initial Calibration (10s) ---");
  Serial.println("Place device flat and keep environment stable.");
  delay(2000); // Wait for sensors to stabilize

  float totalRh=0, totalTemp=0, totalClear=0, totalR=0, totalG=0, totalB=0;
  float totalMagX=0, totalMagY=0, totalMagZ=0;

  for (int i = 0; i < NUM_CALIB_SAMPLES; i++) {
    float x, y, z;
    int r, g, b, c;
    
    totalRh += HS300x.readHumidity();
    totalTemp += HS300x.readTemperature();
    IMU.readMagneticField(x, y, z);
    totalMagX += x; totalMagY += y; totalMagZ += z;
    APDS.readColor(r, g, b, c);
    totalR += r; totalG += g; totalB += b; totalClear += c;
    
    delay(200);
  }
  
  baseRh = totalRh / NUM_CALIB_SAMPLES;
  baseTemp = totalTemp / NUM_CALIB_SAMPLES;
  baseClear = totalClear / NUM_CALIB_SAMPLES;
  baseR = totalR / NUM_CALIB_SAMPLES;
  baseG = totalG / NUM_CALIB_SAMPLES;
  baseB = totalB / NUM_CALIB_SAMPLES;
  
  // Choose magnetic-field metric (magnitude)
  float avgMagX = totalMagX / NUM_CALIB_SAMPLES;
  float avgMagY = totalMagY / NUM_CALIB_SAMPLES;
  float avgMagZ = totalMagZ / NUM_CALIB_SAMPLES;
  baseMag = sqrt(avgMagX*avgMagX + avgMagY*avgMagY + avgMagZ*avgMagZ);

  Serial.println("--- Calibration Complete ---");
  Serial.print("Baseline RH: "); Serial.print(baseRh);
  Serial.print(", Temp: "); Serial.print(baseTemp);
  Serial.print(", Mag: "); Serial.print(baseMag);
  Serial.print(", Clear: "); Serial.println(baseClear);
}

void setup() {
  Serial.begin(115200);
  while (!Serial); // Wait for Serial Monitor

  // Initialize sensors with error checking
  if (!HS300x.begin()) while (1);
  if (!IMU.begin())    while (1); // Starts both BMM150 and BMI270
  if (!APDS.begin())   while (1); // Color/Proximity sensor

  initialCalibration();
  Serial.println("--- Continuous Monitoring Started ---");
}

void loop() {
  unsigned long currentTime = millis();
  bool cooldownActive = (currentTime - lastEventTime < COOLDOWN_MS);

  // 1. DATA ACQUISITION
  float x, y, z;
  int r, g, b, clearVal;
  
  float rh = HS300x.readHumidity();
  float temp = HS300x.readTemperature();
  IMU.readMagneticField(x, y, z);
  float mag = sqrt(x*x + y*y + z*z);
  APDS.readColor(r, g, b, clearVal);

  // 2. BINARY DECISIONS (Rule-Based Modality Flags)
  // Flags are reset each cycle; logic defines behavior
  bool humid_jump = (abs(rh - baseRh) > HUMID_JUMP_THRESH); // Bidirectional for breath
  bool temp_rise = ((temp - baseTemp) > TEMP_RISE_THRESH); // Rise only
  bool mag_shift = (abs(mag - baseMag) > MAG_SHIFT_THRESH); // Bidirectional shift
  
  // Light change is relative percentage deviation from baseline clear
  float clearDiffPercent = abs((float)clearVal - baseClear) / baseClear * 100.0;
  bool light_or_color_change = (clearDiffPercent > CLEAR_CHANGE_PERCENT);

  // 3. RULE-BASED EVENT FUSION AND COOLDOWN (Prioritized)
  String finalLabel = "BASELINE_NORMAL";
  EventState nextState = STATE_NORMAL;

  // PRIORITY 1: BREATH_OR_WARM_AIR_EVENT (Combination Rule)
  if (humid_jump && temp_rise) {
    nextState = STATE_BREATH;
    finalLabel = "BREATH_OR_WARM_AIR_EVENT";
  }
  // PRIORITY 2: MAGNETIC_DISTURBANCE_EVENT
  else if (mag_shift) {
    nextState = STATE_MAGNETIC;
    finalLabel = "MAGNETIC_DISTURBANCE_EVENT";
  }
  // PRIORITY 3: LIGHT_OR_COLOR_CHANGE_EVENT
  else if (light_or_color_change) {
    nextState = STATE_LIGHT;
    finalLabel = "LIGHT_OR_COLOR_CHANGE_EVENT";
  }

  // Prevent re-triggering same event within cooldown period
  if (cooldownActive && currentEvent != STATE_NORMAL && nextState == currentEvent) {
    finalLabel = "BASELINE_NORMAL"; // Force back to normal state
  } else if (nextState != STATE_NORMAL) {
    lastEventTime = currentTime; // Reset cooldown for new event
    currentEvent = nextState;
  } else {
    currentEvent = STATE_NORMAL; // Reset state for Baseline_Normal
  }

  // 4. SERIAL MONITOR OUTPUT (Required Formats)
  Serial.print("raw,rh=");     Serial.print(rh, 1);
  Serial.print(",temp=");       Serial.print(temp, 1);
  Serial.print(",mag=");        Serial.print(mag, 1);
  Serial.print(",r=");          Serial.print(r);
  Serial.print(",g=");          Serial.print(g);
  Serial.print(",b=");          Serial.print(b);
  Serial.print(",clear=");      Serial.println(clearVal);

  Serial.print("flags,humid_jump=");              Serial.print(humid_jump);
  Serial.print(",temp_rise=");                     Serial.print(temp_rise);
  Serial.print(",mag_shift=");                     Serial.print(mag_shift);
  Serial.print(",light_or_color_change=");         Serial.println(light_or_color_change);

  Serial.print("state,");       Serial.println(finalLabel);

  delay(SAMPLE_PERIOD_MS);
}
